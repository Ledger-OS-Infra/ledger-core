              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"SUBSCRIPTION\",\n  \"amount\": {{amountMbuKobo}},\n  \"due_date\": \"2026-10-01\",\n  \"reference_code\": \"MBU-TEST\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/customers/{{customerId}}/obligations",
              "host": ["{{baseUrl}}"],
