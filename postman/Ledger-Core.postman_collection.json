    {
      "name": "Auth",
      "description": "Authentication endpoints. Run Signup then Login before using protected endpoints. Login saves accessToken and refreshToken.",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "1. Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has verification message', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data.message).to.include('check your email');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"{{authName}}\",\n  \"email\": \"{{authEmail}}\",\n  \"password\": \"{{authPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Creates user + workspace + sends verification email. Set authEmail/authPassword/authName in environment."
          },
          "response": []
        },
        {
          "name": "2. Verify email (paste token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Email verified', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Verified message', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data.message).to.include('verified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token=PASTE_TOKEN_FROM_EMAIL_HERE",
              "host": ["{{baseUrl}}"],
