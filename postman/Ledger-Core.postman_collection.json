        {
          "name": "9. Nomba webhook (signed payment)",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var secret = pm.environment.get('nombaWebhookSecret');",
                  "var accountNumber = pm.environment.get('customerAccountNumber');",
                  "var accountRef = pm.environment.get('nombaAccountRef');",
                  "if (!accountNumber || !accountRef) {",
                  "    throw new Error('Run step 2 first.');",
                  "}",
                  "var timestamp = new Date().toISOString();",
                  "var transactionId = 'txn_postman_' + Date.now();",
                  "var requestId = 'req_postman_' + Date.now();",
                  "var payload = {",
                  "    event_type: 'payment_success',",
                  "    requestId: requestId,",
                  "    data: {",
                  "        merchant: {",
                  "            userId: pm.environment.get('webhookMerchantUserId'),",
                  "            walletId: pm.environment.get('webhookMerchantWalletId')",
                  "        },",
                  "        transaction: {",
                  "            transactionId: transactionId,",
                  "            type: 'vact_transfer',",
                  "            time: timestamp,",
                  "            responseCode: '',",
                  "            aliasAccountNumber: accountNumber,",
                  "            aliasAccountName: 'Postman/Test Customer',",
                  "            aliasAccountReference: accountRef,",
                  "            transactionAmount: Number(pm.environment.get('webhookAmountKobo'))",
                  "        },",
                  "        customer: {",
                  "            senderName: 'Postman Test Sender',",
                  "            bankName: 'Test Bank',",
                  "            accountNumber: '0123456789'",
                  "        }",
                  "    }",
                  "};",
                  "var t = payload.data.transaction;",
                  "var m = payload.data.merchant;",
                  "var responseCode = t.responseCode || '';",
                  "if (responseCode === 'null') { responseCode = ''; }",
                  "var hashingPayload = [",
                  "    payload.event_type,",
                  "    payload.requestId,",
                  "    m.userId,",
                  "    m.walletId,",
                  "    t.transactionId,",
                  "    t.type,",
                  "    t.time,",
                  "    responseCode,",
                  "    timestamp",
                  "].join(':');",
                  "var signature = CryptoJS.HmacSHA256(hashingPayload, secret).toString(CryptoJS.enc.Base64);",
                  "pm.request.headers.upsert({ key: 'nomba-signature', value: signature });",
                  "pm.request.headers.upsert({ key: 'nomba-timestamp', value: timestamp });",
                  "pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
                  "pm.request.body.update(JSON.stringify(payload, null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
