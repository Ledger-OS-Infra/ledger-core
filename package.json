{
  "name": "ledger-core",
  "version": "0.1.0",
  "private": true,
  "description": "Universal reconciliation engine built on Nomba Virtual Accounts",
  "scripts": {
    "prepare": "husky",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "db:migrate": "npm run migrate --prefix server",
    "db:seed": "npm run seed --prefix server",
    "db:setup": "npm run db:setup --prefix server",
    "dev": "npm run dev --prefix server",
    "start": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7"
  }
}
