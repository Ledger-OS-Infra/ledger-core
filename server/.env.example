# App
JWT_SECRET=your_jwt_secret
PORT=3050
NODE_ENV=development

# Database & cache
DATABASE_URL=postgresql://user:password@localhost:5432/ledger_core
REDIS_URL=redis://localhost:6379

# Nomba environment: sandbox 
# Use sandbox + TEST credentials during development.
NOMBA_ENV=sandbox
NOMBA_API_BASE_URL=https://sandbox.nomba.com

# Parent (main) account ID — sent as the accountId header on auth and API calls
NOMBA_PARENT_ACCOUNT_ID=your_parent_account_id

# Sub-account ID — scope operations (virtual accounts, balance, transfers)
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id

# Active credentials (TEST for sandbox, LIVE for production)
NOMBA_CLIENT_ID=your_test_client_id
NOMBA_CLIENT_SECRET=your_test_client_secret

# Webhooks — hackathon signing key from Nomba activation form
NOMBA_WEBHOOK_SECRET=NombaHackathon2026
NOMBA_WEBHOOK_PATH=/webhooks/nomba

# Sandbox smoke test — accountRef or bank numbers for getVirtualAccount fallback
NOMBA_SANDBOX_VA_IDENTIFIERS=test_cus_001b,1d285b75-9f45-45bf-a94c-496352dbe44e