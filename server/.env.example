# App
PORT=3050
NODE_ENV=development

# Auth — JWT
JWT_SECRET=your_jwt_secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REQUIRE_EMAIL_VERIFICATION=true

# Emails — dry-run prints to the console instead of SMTP (automatic when NODE_ENV=test).
# MAIL_DRY_RUN=true
# MAIL_SEND=true

# Auth — Email (SMTP via Nodemailer)
# Works with any SMTP provider. For Gmail/Outlook personal accounts, use an
# APP PASSWORD (requires 2FA), not your normal password.
#   Gmail:   SMTP_HOST=smtp.gmail.com        SMTP_PORT=587  SMTP_SECURE=false
# Port 465 → SMTP_SECURE=true. EMAIL_FROM should match SMTP_USER for best delivery.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Ledger-Core <your_email@gmail.com>
FRONTEND_URL=http://localhost:3000

# Database & cache
#
# Local (Docker): docker compose up -d  from repo root
# Hosted (Aiven): copy Service URI from Aiven console — include ?sslmode=require
#
# Same migrate/seed against either target — only DATABASE_URL changes:
#   npm run db:setup --prefix server
#
# Wipe all app data (users, customers, payments) for a fresh start:
#   npm run db:reset --prefix server -- --confirm
#
# TablePlus: use 127.0.0.1 as host (localhost is reserved in TablePlus)
#
# Local
DATABASE_URL=postgresql://user:password@localhost:5432/ledger_core
# DATABASE_SSL=false
#
# Aiven example (replace with your service URI from the console)
# DATABASE_URL=postgresql://avnadmin:PASSWORD@your-service.a.aivencloud.com:12345/defaultdb?sslmode=require
# DATABASE_SSL=true
#
# Aiven signs certs with its own project CA. For full TLS verification, download
# the CA cert from the Aiven console and point to it (or paste it inline):
# DATABASE_CA_CERT_PATH=./certs/aiven-ca.pem
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
#
# Without a CA, SSL still encrypts but skips verification. Set this to force
# strict verification (will fail unless a CA is provided):
# DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Redis / Valkey
# Local (Docker):
REDIS_URL=redis://localhost:6379
# Hosted (Aiven Valkey): the Service URI uses the rediss:// scheme (TLS auto-detected).
# REDIS_URL=rediss://default:PASSWORD@your-valkey.aivencloud.com:12345
# TLS reuses DATABASE_CA_CERT* by default (same Aiven project CA). Override only
# if Valkey lives in a different project:
# REDIS_CA_CERT_PATH=./certs/aiven-ca.pem
# REDIS_TLS_REJECT_UNAUTHORIZED=true
# Force TLS even without a rediss:// URL:
# REDIS_TLS=true

# Nomba — set NOMBA_ENV=production for live, NOMBA_ENV=sandbox to switch back.
# Parent + sub-account IDs are the same on Nomba for both environments.
NOMBA_ENV=production

# Live (active when NOMBA_ENV=production)
NOMBA_API_BASE_URL=https://api.nomba.com
NOMBA_PARENT_ACCOUNT_ID=your_parent_account_id
NOMBA_SUB_ACCOUNT_ID=your_sub_account_id
NOMBA_CLIENT_ID=your_live_client_id
NOMBA_CLIENT_SECRET=your_live_client_secret
NOMBA_WEBHOOK_SECRET=NombaHackathon2026
NOMBA_WEBHOOK_PATH=/webhooks/nomba
PUBLIC_WEBHOOK_URL=https://your-api.example.com/webhooks/nomba

# Sandbox test keys (for test:nomba-sandbox / NOMBA_ENV=sandbox)
NOMBA_SANDBOX_API_BASE_URL=https://sandbox.nomba.com
NOMBA_SANDBOX_CLIENT_ID=your_sandbox_client_id
NOMBA_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret
NOMBA_SANDBOX_VA_IDENTIFIERS=test_cus_001b,1d285b75-9f45-45bf-a94c-496352dbe44e

# Sentry — optional. Create a Node.js project at sentry.io and paste the DSN here.
SENTRY_DSN=
