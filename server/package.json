{
  "name": "nomba-server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "db:bootstrap": "ts-node --transpile-only scripts/bootstrap-business.ts",
    "billing:generate-due": "ts-node -r dotenv/config --transpile-only scripts/generate-due-obligations.ts",
    "seed": "knex seed:run --knexfile knexfile.ts",
    "db:setup": "npm run migrate && npm run db:bootstrap",
    "db:reset": "ts-node -r dotenv/config --transpile-only scripts/reset-db.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:live": "INTEGRATION_LIVE=true vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:nomba-sandbox": "ts-node --transpile-only scripts/test-nomba-sandbox.ts",
    "test:claim-manual": "ts-node -r dotenv/config --transpile-only scripts/test-claim.ts",
    "test:webhook-duplicate": "ts-node -r dotenv/config --transpile-only scripts/test-webhook-duplicate.ts",
    "simulate:webhook": "ts-node -r dotenv/config --transpile-only scripts/print-webhook-request.ts",
    "send:webhook": "ts-node -r dotenv/config --transpile-only scripts/print-webhook-request.ts --send",
    "send:webhook-duplicate": "ts-node -r dotenv/config --transpile-only scripts/test-webhook-duplicate.ts --send",
    "send:claim-manual": "ts-node -r dotenv/config --transpile-only scripts/test-claim.ts --send"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "knex": {
    "ts-node": {
      "transpileOnly": true
    }
  }
}
