{
  "name": "nomba-server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "db:bootstrap": "ts-node --transpile-only scripts/bootstrap-business.ts",
    "seed": "knex seed:run --knexfile knexfile.ts",
    "db:setup": "npm run migrate && npm run seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:nomba-sandbox": "ts-node --transpile-only scripts/test-nomba-sandbox.ts",
    "test:claim-manual": "ts-node --transpile-only scripts/test-claim.ts",
    "test:webhook-duplicate": "ts-node --transpile-only scripts/test-webhook-duplicate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "knex": "^3.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "knex": {
    "ts-node": {
      "transpileOnly": true
    }
  }
}